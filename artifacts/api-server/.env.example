# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database
# Supabase IPv4 pooler format:
# postgresql://postgres.<project-ref>:<db-password>@<pooler-host>:6543/postgres?sslmode=require&uselibpqcompat=true
DATABASE_URL=

# Email delivery
RESEND_API_KEY=
BUSINESS_EMAIL=
ADMIN_EMAILS=frostedlogic007@gmail.com

# Runtime
PORT=3000
CORS_ORIGIN=http://127.0.0.1:5173

# Optional runtime metadata
NODE_ENV=development
LOG_LEVEL=info
